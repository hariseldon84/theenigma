# Enigma OS — Environment Variables
# Copy to .env and fill in: cp .env.example .env
#
# Required for core (Notion + Supabase health + Nexus push):
#   NOTION_API_KEY, NOTION_NEXUS_DATABASE_ID, SUPABASE_URL, SUPABASE_SERVICE_KEY
#
# Required for Vault encrypted store/read:
#   VAULT_ENCRYPTION_KEY
#
# Required for Commitment Capture + Brief LLM (Whisper + classification + translation + synthesis):
#   OPENAI_API_KEY
#
# Optional: leave blank to skip that feature (see comments below).
#
# Logging: LOG_LEVEL (optional). One of DEBUG, INFO, WARNING, ERROR. Default INFO.
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Notion — The Nexus (required for Nexus CRUD)
# -----------------------------------------------------------------------------
NOTION_API_KEY=
NOTION_NEXUS_DATABASE_ID=

# -----------------------------------------------------------------------------
# Supabase — The Vault (required for vault health and encrypted storage)
# -----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# Supabase Auth (optional): set AUTH_REQUIRED=1 to protect /api/* with Bearer JWT.
# SUPABASE_ANON_KEY = anon/public key (Project Settings > API); used by login page.
# SUPABASE_JWT_SECRET = JWT Secret (Project Settings > API > JWT Secret); used to verify tokens.
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im9nZGljb2tqcXdpeWZ5amh2cmlvIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzMxNDg5MDYsImV4cCI6MjA4ODcyNDkwNn0.AeXmO9hbv1SrVEpHg20qmxGiJ3kdLmCgfL9YU7oeoUY
SUPABASE_JWT_SECRET=YXaGyDl4RwGof4Ci1f+hHWgwg1y8KAUfBjqWLMH4sO6kuRHciXGGBPdxwI0XTFtkvdsuilHxNwfRI8mCKPXYrg==
AUTH_REQUIRED=1

# -----------------------------------------------------------------------------
# Vault AES-256 encryption (required for vault-set / vault-get with encryption)
# Generate: python -c "import secrets, base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
# -----------------------------------------------------------------------------
VAULT_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Omni-Scribe (Desktop Sentinel) — optional; default 15 if unset
# -----------------------------------------------------------------------------
NEXUS_PUSH_INTERVAL_MIN=

# -----------------------------------------------------------------------------
# OpenAI — required for audio capture (Whisper), translation, classification, Sovereign Brief
# Get key: https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=

# Default language for Nexus (translated content). Examples: en, English, hi
NEXUS_DEFAULT_LANGUAGE=en

# -----------------------------------------------------------------------------
# Sovereign Brief delivery time (documentation only — CRON uses your chosen schedule)
# Example CRON daily at 09:00: 0 9 * * * ... python -m enigma.main brief
# -----------------------------------------------------------------------------
BRIEF_DELIVERY_TIME=09:00

# -----------------------------------------------------------------------------
# Email — Sovereign Brief delivery via SMTP (optional)
# If any of BRIEF_SMTP_HOST / BRIEF_EMAIL_TO missing, brief is not emailed.
# Gmail: use App Password (2FA on), smtp.gmail.com, port 587
# SendGrid: smtp.sendgrid.net, user often "apikey", password = API key
# -----------------------------------------------------------------------------
BRIEF_EMAIL_TO= anand.arora@gmail.com
BRIEF_SMTP_HOST= smtp.gmail.com
BRIEF_SMTP_PORT=587
BRIEF_SMTP_USER= contact.anand.arora@gmail.com
BRIEF_SMTP_PASSWORD= stpt qetj jqaw lnrp
BRIEF_SMTP_FROM= Enigma <contact.anand.arora@gmail.com>

# -----------------------------------------------------------------------------
# Telegram — Sovereign Brief delivery via Bot API (optional)
# Token: @BotFather after /newbot
# Chat ID: open https://api.telegram.org/bot<TOKEN>/getUpdates after messaging the bot
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN= 8559346487:AAGHulKmU8Fy5ODw2kKB6tOUwB4bqBYGa6k
TELEGRAM_CHAT_ID= 949832829

# FR-3.4 Brief-to-Query: base URL for "Ask follow-up" link in Brief (e.g. https://yourapp.com). If empty, link is path-only.
BRIEF_APP_BASE_URL=
# Optional: path to file storing last brief for follow-up. Default: project root .last_sovereign_brief
BRIEF_LAST_FILE_PATH=

# -----------------------------------------------------------------------------
# Figma — MCP / API (optional; for design-to-code and Figma MCP server)
# Create token: Figma → Settings → Security → Personal access tokens
# Never commit real tokens. For figma-mcp CLI: pass as --figma-api-key or set FIGMA_API_KEY.
# For streamable HTTP MCP (Codex-style): FIGMA_OAUTH_TOKEN as bearer to https://mcp.figma.com/mcp
# -----------------------------------------------------------------------------
FIGMA_ACCESS_TOKEN=
# figma-mcp (Python) reads FIGMA_API_TOKEN — set to same as above if you use .venv-figma-mcp
FIGMA_API_TOKEN=
# FIGMA_OAUTH_TOKEN=   # same token if MCP expects bearer; optional alias
